---
interface Game {
  slug: string;
  name: string;
  tagline: string;
  framework: string;
  dimension: string;
  thumbnail: string;
  status: string;
}

interface Props {
  game: Game;
  heading?: 'h2' | 'h3';
}

const { game, heading = 'h3' } = Astro.props;
const Heading = heading;
---
<article class="game-card">
  <a class="game-card-media" href={`/games/${game.slug}`} aria-hidden="true" tabindex="-1">
    <img src={game.thumbnail} alt="" width="640" height="360" loading="lazy" />
  </a>
  <div class="game-card-body">
    <div class="game-card-top">
      <Heading>
        <a href={`/games/${game.slug}`}>{game.name}</a>
      </Heading>
      <span class="badge">{game.dimension}</span>
    </div>
    <p>{game.tagline}</p>
    <p class="game-meta">{game.framework}</p>
    <div class="tool-card-actions">
      <a class="btn btn-primary" href={`/games/${game.slug}`}>Play</a>
      <a class="btn btn-ghost" href={`/games/${game.slug}#about`}>Details</a>
    </div>
  </div>
</article>

<style>
  .game-card {
    display: flex;
    flex-direction: column;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: border-color 180ms var(--ease), transform 180ms var(--ease);
  }

  .game-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, var(--border));
  }

  .game-card-media {
    display: block;
    aspect-ratio: 16 / 9;
    background: var(--surface-2);
    overflow: hidden;
  }

  .game-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .game-card-body {
    padding: 1.1rem 1.15rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .game-card-top {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .game-card-top :is(h2, h3) {
    margin: 0;
    font-size: 1.1rem;
  }

  .game-card-top a {
    color: var(--text);
    text-decoration: none;
  }

  .game-card-top a:hover {
    color: var(--accent);
  }

  .game-card-body > p {
    margin: 0;
    flex: 1;
  }

  .game-meta {
    font-size: 0.85rem;
    color: var(--muted);
  }

  .tool-card-actions {
    margin-top: 0.35rem;
  }
</style>
