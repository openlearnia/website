---
import BaseLayout from '../layouts/BaseLayout.astro';
import tools from '../data/tools.json';
---
<BaseLayout title="Openlearnia" description="Open tools and learning projects from Openlearnia.">
  <h1>Open tools for curious builders</h1>
  <p>Openlearnia publishes practical software you can run today — starting with Windows desktop tools.</p>
  <h2>Featured tools</h2>
  {tools.map((tool) => (
    <article class="card">
      <h3><a href={`/tools/${tool.slug}`}>{tool.name}</a></h3>
      <p>{tool.tagline}</p>
    </article>
  ))}
</BaseLayout>
