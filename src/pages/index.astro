---
import BaseLayout from '../layouts/BaseLayout.astro';
import ToolCard from '../components/ToolCard.astro';
import tools from '../data/tools.json';

const browserTools = tools.filter((t) => t.type === 'web');
const desktopTools = tools.filter((t) => t.type === 'desktop');
---
<BaseLayout
  title="Openlearnia — Open-Source Browser Tools & Learning Projects"
  description="Privacy-first open-source tools you can run today — image utilities, JSON toolkit, Markdown editor, Database Lab, and more."
>
  <section class="hero reveal" aria-labelledby="hero-heading">
    <p class="brand-mark" aria-hidden="true">Openlearnia</p>
    <h1 id="hero-heading">Tools that stay on your device</h1>
    <p class="lede">
      Privacy-first browser utilities and open-source projects you can run today — no accounts, no uploads, no lock-in.
    </p>
    <div class="cta-row reveal-delay-1">
      <a class="btn btn-primary" href="/tools">Browse tools</a>
      <a class="btn btn-ghost" href="https://github.com/openlearnia" target="_blank" rel="noopener noreferrer">
        View on GitHub
      </a>
    </div>
  </section>

  <section class="reveal reveal-delay-2" aria-labelledby="featured-heading">
    <div class="section-head">
      <h2 id="featured-heading">Browser tools</h2>
      <p>{browserTools.length} live apps · process locally</p>
    </div>
    <div class="tool-grid">
      {browserTools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>

  {desktopTools.length > 0 && (
    <section class="reveal reveal-delay-3" aria-labelledby="desktop-heading">
      <div class="section-head">
        <h2 id="desktop-heading">Desktop</h2>
        <p>Windows apps from the same org</p>
      </div>
      <div class="tool-grid">
        {desktopTools.map((tool) => <ToolCard tool={tool} />)}
      </div>
    </section>
  )}

  <div class="trust-strip reveal reveal-delay-3">
    <span><strong>Local-first</strong> — data stays in your browser</span>
    <span><strong>Open source</strong> — inspect every line on GitHub</span>
    <span><strong>Free</strong> — no paywall, no tracking pitch</span>
  </div>
</BaseLayout>

<style>
  .brand-mark {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: var(--text);
    margin: 0 0 0.75rem;
    line-height: 1.1;
  }

  .brand-mark::after {
    content: "";
    display: inline-block;
    width: 0.45rem;
    height: 0.45rem;
    margin-left: 0.35rem;
    margin-bottom: 0.15rem;
    border-radius: 50%;
    background: var(--accent);
    vertical-align: baseline;
  }

  .hero h1 {
    color: var(--muted);
    font-weight: 500;
    font-size: clamp(1.35rem, 3vw, 1.75rem);
    letter-spacing: -0.02em;
  }
</style>
