---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';
import tools from '../../data/tools.json';
---
<BaseLayout
  title="Open-Source Tools — Openlearnia"
  description="Browse Openlearnia's privacy-first browser utilities and Windows desktop tools — all open source."
>
  <div class="page-intro reveal">
    <h1>Tools</h1>
    <p>
      Browser apps and desktop software from Openlearnia. Most run entirely on your device —
      nothing leaves unless you choose to share it.
    </p>
    <div class="cta-row">
      <a class="btn btn-primary" href="#browser">Jump to browser tools</a>
      <a class="btn btn-ghost" href="https://github.com/openlearnia" target="_blank" rel="noopener noreferrer">
        GitHub org
      </a>
    </div>
  </div>

  <section id="browser" class="reveal reveal-delay-1" aria-labelledby="tools-list-heading">
    <div class="section-head">
      <h2 id="tools-list-heading">All tools</h2>
      <p>{tools.length} projects</p>
    </div>
    <div class="tool-grid">
      {tools.map((tool) => <ToolCard tool={tool} heading="h3" />)}
    </div>
  </section>
</BaseLayout>
