---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Openlearnia — open tools and learning projects.' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0f1117;
        --surface: #1a1d27;
        --text: #e8eaed;
        --muted: #9aa0a6;
        --accent: #6ea8fe;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); }
      header, main, footer { max-width: 960px; margin: 0 auto; padding: 1.5rem; }
      header nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      header nav a { text-decoration: none; color: var(--muted); }
      header nav a:hover { color: var(--text); }
      .card {
        background: var(--surface);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin: 1rem 0;
      }
      footer { color: var(--muted); font-size: 0.9rem; border-top: 1px solid #2a2f3a; }
    </style>
  </head>
  <body>
    <header>
      <p><strong><a href="/" style="color:inherit;text-decoration:none">Openlearnia</a></strong></p>
      <nav>
        <a href="/tools">Tools</a>
        <a href="/learn">Learn</a>
        <a href="/about">About</a>
        <a href="https://github.com/openlearnia">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© {new Date().getFullYear()} Openlearnia</p>
    </footer>
  </body>
</html>
