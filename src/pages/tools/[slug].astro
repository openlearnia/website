---
import BaseLayout from '../../layouts/BaseLayout.astro';
import tools from '../../data/tools.json';

export function getStaticPaths() {
  return tools.map((tool) => ({ params: { slug: tool.slug }, props: { tool } }));
}

interface Props {
  tool: (typeof tools)[number];
}

const { tool } = Astro.props;

const description = tool.description ?? tool.tagline;
const primaryHref = tool.url ?? tool.releases;
const primaryLabel = tool.url ? 'Open app' : 'Download';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: tool.name,
  description,
  applicationCategory: tool.type === 'desktop' ? 'DesktopApplication' : 'WebApplication',
  operatingSystem: tool.platform,
  url: tool.url ?? `https://openlearnia.com/tools/${tool.slug}`,
  ...(tool.releases ? { downloadUrl: tool.releases } : {}),
  offers: {
    '@type': 'Offer',
    price: '0',
    priceCurrency: 'USD',
  },
  author: {
    '@type': 'Organization',
    name: 'Openlearnia',
    url: 'https://openlearnia.com',
  },
  codeRepository: tool.github,
};
---
<BaseLayout
  title={`${tool.name} — Openlearnia`}
  description={description}
  jsonLd={jsonLd}
>
  <article class="tool-detail">
    <p class="reveal">
      <a class="back-link" href="/tools">← All tools</a>
    </p>

    <header class="page-intro reveal reveal-delay-1">
      <div class="title-row">
        <h1>{tool.name}</h1>
        <span class="badge">{tool.platform}</span>
      </div>
      <p class="lede">{tool.tagline}</p>
      {tool.description && <p>{tool.description}</p>}

      <div class="cta-row">
        {primaryHref && (
          <a class="btn btn-primary" href={primaryHref} target="_blank" rel="noopener noreferrer">
            {primaryLabel}
          </a>
        )}
        <a class="btn btn-ghost" href={tool.github} target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
    </header>

    <div class="meta-panel reveal reveal-delay-2">
      <div class="meta-row">
        <span class="meta-label">Platform</span>
        <span class="meta-value">{tool.platform}</span>
      </div>
      {tool.url && (
        <div class="meta-row">
          <span class="meta-label">Live app</span>
          <span class="meta-value">
            <a href={tool.url} target="_blank" rel="noopener noreferrer">{tool.url}</a>
          </span>
        </div>
      )}
      <div class="meta-row">
        <span class="meta-label">Source</span>
        <span class="meta-value">
          <a href={tool.github} target="_blank" rel="noopener noreferrer">{tool.github}</a>
        </span>
      </div>
      {tool.releases && (
        <div class="meta-row">
          <span class="meta-label">Downloads</span>
          <span class="meta-value">
            <a href={tool.releases} target="_blank" rel="noopener noreferrer">GitHub Releases</a>
            {' '}(MSI + portable)
          </span>
        </div>
      )}
      {tool.type === 'web' && (
        <div class="meta-row">
          <span class="meta-label">Privacy</span>
          <span class="meta-value">Runs locally — nothing leaves your device</span>
        </div>
      )}
    </div>

    {tool.features && tool.features.length > 0 && (
      <section class="reveal reveal-delay-3" aria-labelledby="features-heading">
        <h2 id="features-heading">Features</h2>
        <ul>
          {tool.features.map((feature) => <li>{feature}</li>)}
        </ul>
      </section>
    )}
  </article>
</BaseLayout>

<style>
  .back-link {
    color: var(--muted);
    text-decoration: none;
    font-size: 0.9rem;
    font-weight: 500;
  }

  .back-link:hover {
    color: var(--accent);
  }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .title-row h1 {
    margin: 0;
  }

  .lede {
    font-size: 1.15rem;
    color: var(--muted);
  }
</style>
