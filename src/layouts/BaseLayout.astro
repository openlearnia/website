---
interface Props {
  title: string;
  description?: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  noindex?: boolean;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const SITE = 'https://openlearnia.com';
const DEFAULT_DESCRIPTION =
  'Open-source browser tools and learning projects from Openlearnia — privacy-first utilities you can run today.';

const {
  title,
  description = DEFAULT_DESCRIPTION,
  canonicalPath,
  ogType = 'website',
  noindex = false,
  jsonLd,
} = Astro.props;

const canonical = new URL(canonicalPath ?? Astro.url.pathname, SITE).href;
const pageTitle = title.includes('Openlearnia') ? title : `${title} | Openlearnia`;

const defaultJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Openlearnia',
  url: SITE,
  description: DEFAULT_DESCRIPTION,
  publisher: {
    '@type': 'Organization',
    name: 'Openlearnia',
    url: SITE,
    sameAs: ['https://github.com/openlearnia'],
  },
};

const schemas = jsonLd
  ? Array.isArray(jsonLd)
    ? jsonLd
    : [jsonLd]
  : [defaultJsonLd];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow'} />
    <link rel="canonical" href={canonical} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Openlearnia" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />

    <meta name="theme-color" content="#0f1117" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

    {schemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #0f1117;
        --surface: #1a1d27;
        --text: #e8eaed;
        --muted: #9aa0a6;
        --accent: #6ea8fe;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.6;
      }
      a { color: var(--accent); }
      header, main, footer { max-width: 960px; margin: 0 auto; padding: 1.5rem; }
      header nav { display: flex; gap: 1.25rem; flex-wrap: wrap; }
      header nav a { text-decoration: none; color: var(--muted); }
      header nav a:hover { color: var(--text); }
      .card {
        background: var(--surface);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin: 1rem 0;
      }
      footer { color: var(--muted); font-size: 0.9rem; border-top: 1px solid #2a2f3a; }
    </style>
  </head>
  <body>
    <header>
      <p><strong><a href="/" style="color:inherit;text-decoration:none">Openlearnia</a></strong></p>
      <nav>
        <a href="/tools">Tools</a>
        <a href="/learn">Learn</a>
        <a href="/about">About</a>
        <a href="https://github.com/openlearnia">GitHub</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <p>© {new Date().getFullYear()} Openlearnia</p>
    </footer>
  </body>
</html>
